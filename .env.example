# Frontend environment (copy to .env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Must match backend JWT_PUBLIC_KEY (HS256 shared secret). Server-only — never expose as NEXT_PUBLIC_*
AUTH_JWT_SECRET=

# Cookie lifetimes (seconds). Defaults match backend: 15 min access, 7 day refresh.
# AUTH_ACCESS_MAX_AGE_SECONDS=900
# AUTH_REFRESH_MAX_AGE_SECONDS=604800
